{
  "schema_version": "1.1",
  "targets": [
    {
      "id": ".",
      "name": "hmy-next",
      "type": "app",
      "kind": "frontend",
      "runtime": "node",
      "framework": "nextjs",
      "dockerizable": true,
      "closure_hint": [],
      "needs_compose": true,
      "needs_makefile": true,
      "needs_entrypoint": false,
      "base_image_hint": {
        "runtime": "node",
        "version": "20",
        "variant": "bookworm-slim",
        "official_only": true,
        "avoid_latest": true
      },
      "packaging": {
        "app_type": "web",
        "expose_port": 3000,
        "run_command": "next start",
        "dev_command": "next dev",
        "build_command": "next build",
        "output_mode": "server",
        "requires_database_at_runtime": true,
        "requires_migrations": false,
        "recommended_artifacts": [
          "Dockerfile",
          ".dockerignore",
          "compose.yml",
          "Makefile"
        ]
      },
      "compose_plan": {
        "required_services": [
          {
            "name": "app",
            "type": "application"
          },
          {
            "name": "postgres",
            "type": "database",
            "image_hint": "postgres:16"
          }
        ],
        "networks": [
          "default"
        ],
        "volumes": [
          "postgres_data"
        ],
        "depends_on": [
          {
            "service": "app",
            "requires": [
              "postgres"
            ]
          }
        ]
      }
    }
  ]
}
